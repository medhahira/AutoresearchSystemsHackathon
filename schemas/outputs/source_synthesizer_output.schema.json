{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoresearch.local/schemas/outputs/source_synthesizer_output.schema.json",
  "title": "Source Synthesizer Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["round", "side", "synthesized_evidence", "summary"],
  "properties": {
    "round": { "type": "integer", "minimum": 1 },
    "side": { "$ref": "../shared/common.schema.json#/$defs/side" },
    "synthesized_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "../shared/common.schema.json#/$defs/evidenceSnippet" }
    },
    "summary": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
