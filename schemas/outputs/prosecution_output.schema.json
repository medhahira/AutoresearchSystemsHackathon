{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoresearch.local/schemas/outputs/prosecution_output.schema.json",
  "title": "Prosecution Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["round", "speaker", "argument", "claims", "requested_outcome"],
  "properties": {
    "round": { "type": "integer", "minimum": 1 },
    "speaker": { "const": "prosecution" },
    "argument": { "type": "string", "minLength": 1 },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "cited_evidence": {
      "type": "array",
      "items": { "$ref": "../shared/common.schema.json#/$defs/evidenceSnippet" }
    },
    "requested_outcome": { "type": "string", "minLength": 1 }
  }
}
