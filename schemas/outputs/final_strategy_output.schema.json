{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoresearch.local/schemas/outputs/final_strategy_output.schema.json",
  "title": "Final Strategy Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "optimize_for",
    "final_strategy",
    "risk_assessment",
    "settlement_recommendation",
    "next_actions",
    "evidence_gaps"
  ],
  "properties": {
    "optimize_for": { "$ref": "../shared/common.schema.json#/$defs/side" },
    "final_strategy": { "type": "string", "minLength": 1 },
    "risk_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strengths", "weaknesses", "uncertainty", "overall_risk_level"],
      "properties": {
        "strengths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "weaknesses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "uncertainty": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "overall_risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "settlement_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["should_settle", "rationale"],
      "properties": {
        "should_settle": { "type": "boolean" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_gaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
