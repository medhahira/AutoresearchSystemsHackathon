{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoresearch.local/schemas/shared/common.schema.json",
  "title": "Common Shared Types",
  "type": "object",
  "$defs": {
    "side": {
      "type": "string",
      "enum": ["defense", "prosecution"]
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "content"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "source": { "type": "string" },
        "content": { "type": "string", "minLength": 1 }
      }
    },
    "conversationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["round", "speaker", "argument", "timestamp"],
      "properties": {
        "round": { "type": "integer", "minimum": 1 },
        "speaker": {
          "type": "string",
          "enum": ["system", "orchestrator", "prosecution", "defense", "final_strategy"]
        },
        "synthesized_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceSnippet" }
        },
        "argument": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "sourceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_name", "query"],
      "properties": {
        "source_name": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "top_k": { "type": "integer", "minimum": 1, "default": 5 },
        "filters": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        }
      }
    },
    "evidenceSnippet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_name", "snippet", "relevance"],
      "properties": {
        "source_name": { "type": "string", "minLength": 1 },
        "citation": { "type": "string" },
        "snippet": { "type": "string", "minLength": 1 },
        "relevance": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "caseBuilderOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_title",
        "case_summary",
        "facts",
        "prosecution_goals",
        "defense_goals",
        "defense_penalty_exposure",
        "optimize_for"
      ],
      "properties": {
        "case_title": { "type": "string", "minLength": 3 },
        "case_summary": { "type": "string", "minLength": 10 },
        "facts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "prosecution_goals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "defense_goals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "defense_penalty_exposure": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "optimize_for": { "$ref": "#/$defs/side" }
      }
    }
  }
}
